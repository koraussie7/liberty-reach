{
	servers {
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22
	}
}

privseai.com {
	# Cloudflare handles edge HTTPS; use internal cert for origin
	tls internal

	root * /var/www/privseai/build/web
	file_server

	handle /vision* {
		root * /var/www/privseai/vision
		file_server {
			index index.html
		}
	}

	handle /api/* {
		reverse_proxy localhost:8000
	}

	handle /upload* {
		reverse_proxy localhost:8501
	}

	handle /importer* {
		reverse_proxy localhost:8502
	}

	handle /health {
		reverse_proxy localhost:8000
	}
	handle /ai/* {
		reverse_proxy localhost:8000
	}
	handle /opencode/* {
		reverse_proxy localhost:8000
	}
	handle /blockchain/* {
		reverse_proxy localhost:8000
	}
	handle /minima/* {
		reverse_proxy localhost:8000
	}
	handle /leaderboard/* {
		reverse_proxy localhost:8000
	}
	handle /loops/* {
		reverse_proxy localhost:8000
	}
	handle /commerce/* {
		reverse_proxy localhost:8000
	}
	handle /ws/* {
		reverse_proxy localhost:8000
	}

	# Puter Hermes Terminal (standalone access)
	handle_path /hermes/* {
		root * /var/www/privseai/puter-apps/hermes-terminal
		file_server
	}

	# 보안 헤더
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; font-src 'self' data: https:; connect-src 'self' ws: wss: https: http:; media-src 'self' https: blob:; worker-src 'self' blob:;"
	}

	encode gzip zstd
}

