generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]

  @@map("users")
}

enum Role {
  CUSTOMER
  ADMIN
}

// ─── PRODUCTS ─────────────────────────────────────────────────────────────────

model Product {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  description   String
  images        String[]
  category      String
  tags          String[]
  customerPrice Decimal   @db.Decimal(10, 2)
  supplierCost  Decimal   @db.Decimal(10, 2)
  stock         Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orderItems    OrderItem[]

  @@map("products")
}

// ─── ORDERS ──────────────────────────────────────────────────────────────────

model Order {
  id                String      @id @default(cuid())
  userId            String?
  user              User?       @relation(fields: [userId], references: [id])
  customerEmail     String
  customerName      String
  status            OrderStatus @default(PENDING)
  stripeSessionId   String?     @unique
  trackingNumber    String?
  shippingAddress   Json
  items             OrderItem[]
  totalAmount       Decimal     @db.Decimal(10, 2)
  supplierForwarded Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("orders")
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)

  @@map("order_items")
}

enum OrderStatus {
  PENDING
  PAID
  FORWARDED_TO_SUPPLIER
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

// ─── SUPPLIERS (Module 2 stub) ────────────────────────────────────────────────

model Supplier {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  website   String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("suppliers")
}
